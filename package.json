{
  "name": "wpei-backend",
  "version": "1.0.0",
  "description": "WPEI Backend API Server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
